# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# local configuration and credentials
.env*
*.pem
*.key
*.p8
*.p12
*.pfx
/supabase/.temp/

# machine-specific files
.DS_Store

