npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# deployment metadata
/.vercel/

# typescript
*.tsbuildinfo
next-env.d.ts

.tmp-bun/
.vscode/
.superpowers/
